# --- Transport ---------------------------------------------------------------
# "stdio" (default, for Claude Desktop / local CLI clients) or "http"
BOOKIE_TRANSPORT=stdio
# Port for the HTTP transport (Railway sets PORT automatically)
PORT=3000

# --- Database (Neon Postgres) ------------------------------------------------
# ONE ledger. EVERY instance (local stdio + deployed HTTP) points at the same
# database, so the books are always identical.
#
#   BOOKIE_DB_URL         pooled connection string (runtime queries)
#   BOOKIE_DB_DIRECT_URL  direct connection string (prisma db push / migrations)
#
# Get both from `neonctl connection-string <branch> --project-id <id>` or the
# Neon dashboard. Use the production branch in production; a dev branch locally.
BOOKIE_DB_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
BOOKIE_DB_DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require

# --- Auth (HTTP transport) ---------------------------------------------------
# BOOKIE_API_KEY: static bearer token for Claude Desktop / direct API access.
# If unset, the HTTP endpoint is OPEN (fine for localhost only).
# Set a long random value before exposing the server publicly.
BOOKIE_API_KEY=

# --- OAuth 2.0 (Claude.ai connector) -----------------------------------------
# Required to add bookie as a custom connector on claude.ai.
#
#   PUBLIC_URL     the public HTTPS base URL of the deployed server (no trailing slash)
#   JWT_SECRET     64-char hex secret for HS256 JWT signing — generate with:
#                  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   OAUTH_CLIENT_ID  client ID allowlisted for the Claude.ai connector
#                    (default: "claude-ai-connector")
PUBLIC_URL=https://your-app.up.railway.app
JWT_SECRET=
OAUTH_CLIENT_ID=claude-ai-connector

# --- Email delivery (send_report) --------------------------------------------
# https://resend.com — needed only for the send_report tool
RESEND_API_KEY=
# Verified sender, e.g. "Bookie <reports@yourdomain.com>"
BOOKIE_REPORT_FROM=
